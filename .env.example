# ===== WhatsApp Cloud API (Meta) =====
# NO cambiar estos nombres de variable: ya están en uso.
VERIFY_TOKEN=music_bot_verify_token
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=1141140719082740
WHATSAPP_API_VERSION=v25.0

# ===== Administradores =====
# Números autorizados separados por comas (con código de país, sin +).
# Ej: 519XXXXXXXX,519YYYYYYYY
ADMIN_PHONE_NUMBERS=

# ===== Google Sheets (opcional) =====
# Si está en false o faltan credenciales, el bot funciona con memoria temporal.
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# ===== Identidad de la agrupación =====
BOT_NAME=Music Bot
GROUP_NAME=Nombre de la agrupación

# ===== IA / Gemini (opcional, RESPALDO inteligente) =====
# El bot funciona perfectamente SIN Gemini. Solo se usa como fallback cuando las
# reglas no entienden el mensaje. Si está deshabilitado o falta la API key, el
# bot sigue respondiendo con reglas/intents/fuzzy + Google Sheets.
#
# Variables existentes (compatibilidad):
AI_ENABLED=false
GEMINI_API_KEY=
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
#
# Variables nuevas (opcionales, alias claros para Gemini). No son obligatorias:
#   - GEMINI_ENABLED: alternativa a AI_ENABLED (con que una esté en true basta).
#   - GEMINI_MODEL:   si se define, tiene prioridad sobre AI_MODEL.
GEMINI_ENABLED=false
GEMINI_MODEL=gemini-1.5-flash
