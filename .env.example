# ===== WhatsApp Cloud API (Meta) =====
# NO cambiar estos nombres de variable: ya están en uso.
VERIFY_TOKEN=music_bot_verify_token
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=1141140719082740
WHATSAPP_API_VERSION=v25.0

# ===== Administradores =====
# Números autorizados separados por comas (con código de país, sin +).
# Ej: 519XXXXXXXX,519YYYYYYYY
ADMIN_PHONE_NUMBERS=

# ===== Google Sheets (opcional) =====
# Si está en false o faltan credenciales, el bot funciona con memoria temporal.
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# ===== Identidad de la agrupación =====
BOT_NAME=Music Bot
GROUP_NAME=Nombre de la agrupación
